{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@shared/*": ["./shared/*"]
    },
    "jsx": "react-jsx"
  },
  "include": ["server/**/*", "shared/**/*", "client/**/*", "src/**/*"],
  "exclude": ["node_modules", "dist"]
}
